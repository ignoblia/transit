# TransIT API Configuration
# ============================
# Most data sources are now free and require no API keys:
#   - Equaldex: free
#   - REST Countries: free
#   - World Bank (economic data): free
#   - Visa (passport-index-data via GitHub): free
#   - UNHCR (refugee data): free
#
# Fill in below only if you want additional premium data sources.

# Server port (default 3001)
PORT=3001

# Numbeo API (PREMIUM - only if you purchase a plan)
# Paid API at https://www.numbeo.com/common/api.jsp
# Without this, the site still works using free alternatives.
NUMBEO_API_KEY=

# Visa API key (OPTIONAL - only if you prefer a premium visa API)
# Service: Travel Buddy (free tier: 200 requests/month)
# https://travel-buddy.ai/api/
# Without this, the free passport-index-data from GitHub is used.
VISA_API_KEY=

# Refresh schedule (cron expression, default: daily at 3am)
# Format: minute hour day-of-month month day-of-week
REFRESH_CRON_SCHEDULE=0 3 * * *
