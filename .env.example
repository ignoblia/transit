# TransIT API Configuration
# Copy this file to .env and fill in your keys

# Server
PORT=3001

# Numbeo API (required for cost of living data)
# Get a free key at: https://www.numbeo.com/api/
NUMBEO_API_KEY=

# Equaldex API
EQUALDEX_API_URL=https://www.equaldex.com/api/equality-index?format=json

# REST Countries API
REST_COUNTRIES_URL=https://restcountries.com/v3.1/all?fields=name,cca2,flags,capital,region,subregion,population,languages,continents,currencies

# Refresh schedule (cron expression, default: daily at 3am)
# Format: minute hour day-of-month month day-of-week
REFRESH_CRON_SCHEDULE=0 3 * * *
